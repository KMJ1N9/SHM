# ── 校园二手交易小程序 — Java 后端环境变量模板 ──
# 复制此文件为 .env 并填入真实值：cp .env.example .env
# .env 文件受 .gitignore 保护，不会上传到 Git

# MySQL
DB_URL=jdbc:mysql://127.0.0.1:3306/campus_market_dev?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# JWT (生成方式: openssl rand -hex 32)
JWT_ACCESS_SECRET=your_256bit_hex_key
JWT_REFRESH_SECRET=your_256bit_hex_key

# 微信小程序
WX_APP_ID=your_wechat_appid
WX_APP_SECRET=your_wechat_appsecret

# 腾讯云 IM
IM_SDK_APP_ID=0
IM_SECRET_KEY=your_im_secret_key

# 腾讯云 COS
COS_BUCKET=your_cos_bucket
COS_REGION=ap-guangzhou
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key

# 内部 API 共享密钥（本地开发留空 = 放行）
INTERNAL_TOKEN=
