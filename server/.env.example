# ============================================================
# 校园二手交易小程序 — 环境变量模板
# 来源：docs/技术架构文档.md §11.2.2
#
# 使用方式：
#   cp .env.example .env.development   # 开发环境
#   cp .env.example .env.staging       # 预发布环境
#   cp .env.example .env.production    # 生产环境
#
# 注意：
#   - .env.* 文件（除 .env.example 外）均不入库（已在 .gitignore 中）
#   - 标记"必填"的变量必须配置，否则启动时校验失败
#   - 密钥类变量严禁提交到 Git
# ============================================================

# ---- 服务器 ----
PORT=3000
NODE_ENV=development

# ---- 微信小程序 ----
WX_APPID=                        # 必填：小程序 AppID
WX_APPSECRET=                    # 必填：小程序 AppSecret（严格保密）

# ---- JWT ----
JWT_ACCESS_SECRET=               # 必填：Access Token 签名密钥（建议随机 64 位 hex）
JWT_REFRESH_SECRET=              # 必填：Refresh Token 签名密钥（建议随机 64 位 hex）
JWT_ACCESS_EXPIRES=7d
JWT_REFRESH_EXPIRES=30d

# ---- 腾讯云 IM ----
IM_SDK_APP_ID=                   # 必填：IM 应用 SDKAppID
IM_SECRET_KEY=                   # 必填：IM 应用密钥（严格保密）
IM_ADMIN_ACCOUNT=admin           # IM 管理员账号（系统消息发送者）

# ---- 腾讯云 COS（对象存储）----
COS_BUCKET=                      # 必填：COS Bucket 名称（如 shm-xxxxxxxx）
COS_REGION=ap-guangzhou          # 必填：COS 区域
COS_SECRET_ID=                   # 必填：COS SecretId
COS_SECRET_KEY=                  # 必填：COS SecretKey（严格保密）
COS_CDN_BASE_URL=                # 可选：CDN 加速域名（默认使用 COS 源站域名）
COS_UPLOAD_MAX_SIZE=5242880      # 上传大小限制（字节，默认 5MB）
COS_UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ---- MySQL ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=                     # 必填：MySQL 密码
DB_NAME=campus_market_dev        # 必填：各环境数据库名不同

# ---- 日志 ----
LOG_LEVEL=debug                  # winston 日志级别：debug | info | warn | error
LOG_DIR=./logs

# ---- 限流 ----
RATE_LIMIT_GLOBAL=60             # 全局限流（请求/分钟）
RATE_LIMIT_SENSITIVE=10          # 敏感接口限流（请求/分钟，登录/注册/验证码）

# ---- CORS ----
CORS_ORIGIN=*

# ---- 定时任务 ----
ENABLE_CRON=true                 # 是否启用定时任务（多实例部署时仅主实例设为 true）

# ---- 信誉分 ----
CREDIT_INITIAL=100               # 新用户初始信誉分
CREDIT_MAX=200                   # 信誉分上限
CREDIT_DEDUCT_REPORT=30          # 举报成立扣分
CREDIT_REWARD_TRANSACTION=2      # 完成交易加分
CREDIT_REWARD_POSITIVE_REVIEW=1  # 好评加分
CREDIT_DEDUCT_NEGATIVE_REVIEW=5  # 差评扣分
CREDIT_PUBLISH_THRESHOLD=60      # 禁止发布商品信誉分阈值
CREDIT_TRADE_THRESHOLD=30        # 禁止交易信誉分阈值

# ---- 举报 SLA ----
REPORT_RESPONSE_SLA_HOURS=3      # 举报响应 SLA（小时）
REPORT_RESOLVE_SLA_DAYS=3        # 举报办结 SLA（工作日）
